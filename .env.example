# Thynx — Self-Hosted Voice App
# Copy to .env and fill in production values

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# ── Database (optional — only needed if you add user accounts) ───────────────
DATABASE_URL=

# ── Self-hosted TTS (Chatterbox) ─────────────────────────────────────────────
# Points to the chatterbox Docker service — no change needed in Docker Compose
TTS_API_URL=http://chatterbox:8880

# ── Self-hosted STT (faster-whisper) ─────────────────────────────────────────
# Points to the whisper Docker service — no change needed in Docker Compose
STT_API_URL=http://whisper:9000
